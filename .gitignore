# Ignore everything
*

# But track these specific workspace directories
!workspace-main/
!workspace-jinfei/
!workspace-xuanji/
!workspace-yehuang/

# Inside each workspace, track specific file types
workspace-main/*.md
workspace-jinfei/*.md
workspace-xuanji/*.md
workspace-yehuang/*.md
workspace-main/*.json
workspace-jinfei/*.json
workspace-xuanji/*.json
workspace-yehuang/*.json
workspace-main/*.py
workspace-jinfei/*.py
workspace-xuanji/*.py
workspace-yehuang/*.py
workspace-main/*.toml
workspace-jinfei/*.toml
workspace-xuanji/*.toml
workspace-yehuang/*.toml
workspace-main/*.txt
workspace-jinfei/*.txt
workspace-xuanji/*.txt
workspace-yehuang/*.txt
workspace-main/*.skill
workspace-jinfei/*.skill
workspace-xuanji/*.skill
workspace-yehuang/*.skill

# Track memory directories
workspace-main/memory/
workspace-jinfei/memory/
workspace-xuanji/memory/
workspace-yehuang/memory/
!workspace-main/memory/
!workspace-jinfei/memory/
!workspace-xuanji/memory/
!workspace-yehuang/memory/
workspace-main/memory/*
workspace-jinfei/memory/*
workspace-xuanji/memory/*
workspace-yehuang/memory/*
!workspace-main/memory/*.md
!workspace-jinfei/memory/*.md
!workspace-xuanji/memory/*.md
!workspace-yehuang/memory/*.md

# Track skills directories
workspace-main/skills/
workspace-jinfei/skills/
workspace-xuanji/skills/
workspace-yehuang/skills/
!workspace-main/skills/
!workspace-jinfei/skills/
!workspace-xuanji/skills/
!workspace-yehuang/skills/
workspace-main/skills/*/
workspace-jinfei/skills/*/
workspace-xuanji/skills/*/
workspace-yehuang/skills/*/
!workspace-main/skills/*/*.md
!workspace-jinfei/skills/*/*.md
!workspace-xuanji/skills/*/*.md
!workspace-yehuang/skills/*/*.md
!workspace-main/skills/*/SKILL.md
!workspace-jinfei/skills/*/SKILL.md
!workspace-xuanji/skills/*/SKILL.md
!workspace-yehuang/skills/*/SKILL.md

# Large/binary/cache files to ignore
workspace-main/.clawhub/
workspace-main/.openclaw/
workspace-main/gmcache/
workspace-main/__pycache__/
workspace-main/.venv/
workspace-jinfei/.clawhub/
workspace-jinfei/.openclaw/
workspace-jinfei/gmcache/
workspace-jinfei/__pycache__/
workspace-jinfei/.venv/
workspace-xuanji/.clawhub/
workspace-xuanji/.openclaw/
workspace-xuanji/gmcache/
workspace-xuanji/__pycache__/
workspace-xuanji/.venv/
workspace-yehuang/.clawhub/
workspace-yehuang/.openclaw/
workspace-yehuang/gmcache/
workspace-yehuang/__pycache__/
workspace-yehuang/.venv/
*.pyc
*.pyo
*.egg-info/
.DS_Store
Thumbs.db
uv.lock

# Extra files in workspaces (not core agent files)
workspace-main/clawgram*
workspace-main/moltbook*
workspace-main/package*
workspace-main/tavily*
workspace-main/TOOLS_backup*
workspace-jinfei/clawgram*
workspace-jinfei/moltbook*
workspace-jinfei/package*
workspace-jinfei/tavily*
workspace-jinfei/backtest_*.txt
workspace-xuanji/clawgram*
workspace-xuanji/moltbook*
workspace-xuanji/package*
workspace-xuanji/tavily*
workspace-xuanji/TOOLS_backup*
workspace-yehuang/clawgram*
workspace-yehuang/moltbook*
workspace-yehuang/package*
workspace-yehuang/tavily*
workspace-yehuang/TOOLS_backup*
